# =============================================================================
# database.env - 배포용 데이터베이스 설정
# 키 이름 기준:
#   - 백엔드(Node.js): POSTGRES_*, MARIADB_*, MSSQL_*
#   - C++ Collector:   POSTGRES_*, MYSQL_* (MariaDB→MYSQL_ 접두사)
#   - DATABASE_TYPE 값: SQLITE | MARIADB | POSTGRESQL | MSSQL
# =============================================================================

DATABASE_TYPE=SQLITE

# ==========================================================================
# SQLite (기본값)
# ==========================================================================
SQLITE_ENABLED=true
SQLITE_PATH=./data/db/pulseone.db
SQLITE_BACKUP_PATH=./data/backup/
SQLITE_LOGS_PATH=./data/logs/
SQLITE_TEMP_PATH=./data/temp/

SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_CACHE_SIZE=2000
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_FOREIGN_KEYS=true

# ==========================================================================
# PostgreSQL (DATABASE_TYPE=POSTGRESQL 일 때 활성화)
# 백엔드: POSTGRES_DATABASE / C++: POSTGRES_DB
# ==========================================================================
POSTGRES_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=pulseone
POSTGRES_DB=pulseone
POSTGRES_USER=pulseone
POSTGRES_PASSWORD=
POSTGRES_POOL_SIZE=10
POSTGRES_SSL=false

# ==========================================================================
# MariaDB (DATABASE_TYPE=MARIADB 일 때 활성화)
# 백엔드: MARIADB_* 키 / C++ Collector: MYSQL_* 키 (MariaDB 프로토콜 호환)
# ==========================================================================
MARIADB_ENABLED=false
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=pulseone
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_POOL_SIZE=10
MARIADB_CHARSET=utf8mb4

# C++ Collector 호환 (MariaDB를 MYSQL_* 접두사로 읽음)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=pulseone
MYSQL_USER=root
MYSQL_PASSWORD=

# ==========================================================================
# MSSQL / SQL Server (DATABASE_TYPE=MSSQL 일 때 활성화, Windows 전용)
# 백엔드: MSSQL_* 키
# ==========================================================================
MSSQL_ENABLED=false
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=pulseone
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_INSTANCE=
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_POOL_SIZE=10
