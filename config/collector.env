# =============================================================================
# config/collector.env - Collector 설정
# =============================================================================

# Collector 실행 파일 경로
# Collector 실행 설정
COLLECTOR_EXECUTABLE_PATH=/app/core/collector/bin/pulseone-collector
AUTO_BUILD=true
DEBUG_MODE=true

# Collector API 서버
COLLECTOR_HOST=collector
COLLECTOR_PORT=8080
api.port=8080

# 헬스체크 및 타임아웃 (밀리초)
COLLECTOR_HEALTH_CHECK_INTERVAL_MS=30000
COLLECTOR_START_TIMEOUT_MS=10000
COLLECTOR_STOP_TIMEOUT_MS=5000

# 자동 재시작
COLLECTOR_AUTO_RESTART=true
COLLECTOR_MAX_RESTART_ATTEMPTS=3
COLLECTOR_RESTART_DELAY_MS=5000

# 로그 설정
COLLECTOR_DEBUG_MODE=false
COLLECTOR_LOG_LEVEL=info
COLLECTOR_LOG_TO_FILE=true
COLLECTOR_LOG_FILE_PATH=./logs/collector.log