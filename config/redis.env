# redis.env - PulseOne 설정 파일
# 자동 생성됨: 2026-01-31 09:02:42

REDIS_HOST=redis
DEV_REDIS_DEBUG=false               # Redis 명령어 로그
DEV_REDIS_FLUSH_ON_START=false      # 주의: 모든 캐시 삭제
REDIS_COMMAND_TIMEOUT_MS=10000     # 10초
REDIS_CONNECTION_TIMEOUT_MS=30000  # 30초
REDIS_DB_CACHE=0                    # 일반 캐시
REDIS_DB_QUEUES=3                   # 작업 큐
REDIS_DB_REALTIME=2                 # 실시간 데이터
REDIS_DB_SESSIONS=1                 # 사용자 세션
REDIS_DEFAULT_TTL_SEC=3600          # 1시간
REDIS_POOL_MAX_ACTIVE=10
REDIS_POOL_MAX_IDLE=3
REDIS_POOL_MAX_WAIT_MS=5000
REDIS_POOL_SIZE=5
REDIS_PORT=6379
REDIS_PRIMARY_CONNECT_TIMEOUT_MS=3000
REDIS_PRIMARY_DB=0
REDIS_PRIMARY_ENABLED=true
REDIS_PRIMARY_HOST=redis
REDIS_PRIMARY_PASSWORD=
REDIS_PRIMARY_PORT=6379
REDIS_PRIMARY_TIMEOUT_MS=5000
REDIS_REALTIME_TTL_SEC=300          # 5분
REDIS_SESSION_TTL_SEC=28800         # 8시간
REDIS_TCP_KEEPALIVE=true
